# Copie para .env e ajuste os valores. NUNCA versione o .env real.
SECRET_KEY=change-me-generate-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (docker-compose expõe em localhost:5432)
# connect_timeout evita travar indefinidamente quando o banco está fora do ar
DATABASE_URL=postgres://morse:morse@localhost:5432/morse?connect_timeout=5

# Redis (docker-compose expõe em localhost:6379)
REDIS_URL=redis://localhost:6379/0

# Origens liberadas para CORS (frontend Angular em dev)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Em produção atrás de um reverse proxy que termina TLS, ligue para o
# redirect HTTPS confiar no header X-Forwarded-Proto do proxy.
USE_X_FORWARDED_PROTO=False
